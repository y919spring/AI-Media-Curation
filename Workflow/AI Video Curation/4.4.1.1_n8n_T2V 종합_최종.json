        "jsCode": "return $input.all().map((item) => {\n  // 원본 가사 안전하게 가져오기\n  const rawText = item.json.output?.[0]?.content?.[0]?.text || \"\";\n\n  // 가사 정리 (기존과 동일한 로직)\n  const cleanedText = rawText\n    .replace(/\\[Lyrics\\]:/g, \"\")\n    .replace(/\\n/g, \" \")\n    .trim();\n\n  return {\n    json: {\n      ...item.json,     // ← 기존 데이터(아이디, Sound Type 등) 모두 유지!\n      text: cleanedText // ← 정제된 가사 (이후 노드에서 그대로 {{ $json.text }} 사용 가능)\n    }\n  };\n});"
      },
