      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const cloudName = \"dk7gzkbvz\";\nconst voiceId = $('Cloudinary_audio').item.json.public_id;\nconst bgmId = $('Cloudinary_BGM').item.json.public_id;\n\n// BGM 볼륨 10% (10~30 사이 조절)\nconst mixedUrl = `https://res.cloudinary.com/${cloudName}/video/upload/l_video:${bgmId},e_volume:10/fl_layer_apply/${voiceId}.mp3`;\n\nreturn { json: { mixedUrl } };"
      },
