    {
      "parameters": {
        "jsCode": "return $input.all().map(item => {\n  // 1. 원본 텍스트 가져오기 (경로가 맞는지 확인: 필요시 수정)\n  let rawText = item.json?.content?.parts?.[0]?.text || \n                item.json?.text || \n                item.json?.output?.[0]?.content?.[0]?.text || \n                \"\";\n\n  // 2. 가사 관련 불필요한 패턴 제거 (필요에 따라 추가/수정)\n  let cleanedText = rawText\n    .replace(/^```json\\s*/i, \"\")\n    .replace(/^```\\s*/i, \"\")\n    .replace(/```\\s*$/g, \"\")\n    .replace(/\\[Lyrics\\]:?/gi, \"\")           // [Lyrics]: 또는 [Lyrics] 제거\n    .replace(/\\[Verse \\d+\\]/gi, \"\")          // [Verse 1], [Verse 2] 등\n    .replace(/\\[Chorus\\]/gi, \"\")\n    .replace(/\\[Bridge\\]/gi, \"\")\n    .replace(/\\[Outro\\]/gi, \"\")\n    .replace(/\\([^\\)]*\\)/g, \"\")              // 괄호 안 내용 제거 (예: (laughs))\n    .replace(/\\n+/g, \" \")                    // 여러 개행 → 한 칸 공백\n    .replace(/\\r/g, \"\")                      // \\r 제거\n    .replace(/\\s+/g, \" \")                    // 연속 공백 → 한 칸\n    .trim();                                 // 앞뒤 공백 제거\n\n  // 3. 빈 문자열이면 fallback (MiniMax 에러 방지)\n  if (!cleanedText || cleanedText.length < 1) {\n    cleanedText = \"이것은 목소리 테스트용 기본 문장입니다. 확인 부탁드려요.\";\n  }\n\n  // 4. JSON 문자열로 안전하게 사용할 수 있도록 (큰따옴표 이스케이프 등)\n  //    → 다음 노드에서 그대로 \"{{ $json.cleaned_text }}\" 쓰면 됨\n  return {\n    json: {\n      ...item.json,              // 기존 데이터 유지 (voice_id 등 필요시)\n      raw_text: rawText,         // 디버깅용 원본 (필요하면 삭제 가능)\n      cleaned_text: cleanedText  // 정리된 최종 텍스트\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1072,
        -1264
      ],
      "id": "17b9ff51-a630-46a6-b418-9f2744ccf0cd",
      "name": "pod_text refiner",
      "executeOnce": false
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// 1. cleaned_text 가져오기\nconst cleanedText = $json.cleaned_text || $json.raw_text || \"\";\n\n// 2. 파싱 (JSON 형식 / \"A: 내용\" 형식 둘 다 대응)\nlet turns = [];\ntry {\n  const parsed = JSON.parse(cleanedText);\n  if (Array.isArray(parsed)) {\n    turns = parsed.map(p => ({ speaker: p.speaker, text: p.text }));\n  }\n} catch(e) {\n  const lines = cleanedText.split(/(?=[A-C]:)/).filter(line => line.trim());\n  for (const line of lines) {\n    const match = line.match(/^([A-C]):\\s*(.+)$/s);\n    if (match) {\n      turns.push({ speaker: match[1], text: match[2].trim() });\n    }\n  }\n}\n\n// 3. voiceMap\nconst voiceMap = {\n  \"A\": \"Roger\",\n  \"B\": \"Laura\",\n  \"C\": \"Will\"\n};\n\n// 4. return\nreturn {\n  json: {\n    model_id: \"eleven_v3\",\n    output_format: \"mp3_44100_128\",\n    transcript: turns.map(t => ({\n      text: t.text,\n      voice_id: voiceMap[t.speaker] || \"Aria\"\n    }))\n  }\n};"
      },
