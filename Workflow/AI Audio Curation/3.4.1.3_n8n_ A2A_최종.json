    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// 1. Gemini 노드(K_Analyze_BGM)에서 온 텍스트를 가져옵니다.\nconst rawText = $json.content.parts[0].text;\n\n// 2. 소수점을 포함한 숫자를 추출하기 위해 정규표현식을 수정합니다.\nconst durationMatch = rawText.match(/DURATION_START:\\s*([\\d.]+)/);\n\n// 3. parseFloat을 사용하여 소수점까지 숫자로 변환합니다.\nconst duration = durationMatch ? parseFloat(durationMatch[1]) : 0;\n\n// 4. 전사 텍스트 추출\nconst transcription = rawText.replace(/DURATION_START:.*?DURATION_END/, \"\").trim();\n\nreturn {\n  json: {\n    duration: duration,\n    transcription: transcription\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1056,
        -1072
      ],
      "id": "3410a7ae-72b1-421e-aa16-180b95860491",
      "name": "BGM_refiner",
      "executeOnce": false
    },
    {
      "parameters": {
        "jsCode": "return $input.all().map(item => {\n  // 1. 원본 텍스트 가져오기 (경로가 맞는지 확인: 필요시 수정)\n  let rawText = item.json?.content?.parts?.[0]?.text || \n                item.json?.text || \n                item.json?.output?.[0]?.content?.[0]?.text || \n                \"\";\n\n  // 2. 가사 관련 불필요한 패턴 제거 (필요에 따라 추가/수정)\n  let cleanedText = rawText\n    .replace(/\\[Lyrics\\]:?/gi, \"\")           // [Lyrics]: 또는 [Lyrics] 제거\n    .replace(/\\[Verse \\d+\\]/gi, \"\")          // [Verse 1], [Verse 2] 등\n    .replace(/\\[Chorus\\]/gi, \"\")\n    .replace(/\\[Bridge\\]/gi, \"\")\n    .replace(/\\[Outro\\]/gi, \"\")\n    .replace(/\\([^\\)]*\\)/g, \"\")              // 괄호 안 내용 제거 (예: (laughs))\n    .replace(/\\n+/g, \" \")                    // 여러 개행 → 한 칸 공백\n    .replace(/\\r/g, \"\")                      // \\r 제거\n    .replace(/\\s+/g, \" \")                    // 연속 공백 → 한 칸\n    .trim();                                 // 앞뒤 공백 제거\n\n  // 3. 빈 문자열이면 fallback (MiniMax 에러 방지)\n  if (!cleanedText || cleanedText.length < 1) {\n    cleanedText = \"이것은 목소리 테스트용 기본 문장입니다. 확인 부탁드려요.\";\n  }\n\n  // 4. JSON 문자열로 안전하게 사용할 수 있도록 (큰따옴표 이스케이프 등)\n  //    → 다음 노드에서 그대로 \"{{ $json.cleaned_text }}\" 쓰면 됨\n  return {\n    json: {\n      ...item.json,              // 기존 데이터 유지 (voice_id 등 필요시)\n      raw_text: rawText,         // 디버깅용 원본 (필요하면 삭제 가능)\n      cleaned_text: cleanedText  // 정리된 최종 텍스트\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
